   "source": [
    "import torch\n",
    "\n",
    "# Check if CUDA is available\n",
    "cuda_available = torch.cuda.is_available()\n",
    "print(f\"Is GPU available? {cuda_available}\")\n",
    "\n",
    "if cuda_available:\n",
    "    print(f\"GPU Name: {torch.cuda.get_device_name(0)}\")"
